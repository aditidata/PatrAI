# PatrAI environment variables — copy to .env and fill in real values.
# Never commit .env to version control.

# OpenAI (fallback LLM)
OPENAI_API_KEY=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Assistant Gmail account
ASSISTANT_EMAIL=
ASSISTANT_EMAIL_PASSWORD=

# IMAP / SMTP servers (defaults shown)
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com

# Infrastructure (defaults shown)
REDIS_URL=redis://localhost:6379
DUCKLING_URL=http://localhost:8000
OLLAMA_BASE_URL=http://localhost:11434

# SQLite database path (default shown)
DB_PATH=patrai.db

# Fernet encryption key for OAuth token storage.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
